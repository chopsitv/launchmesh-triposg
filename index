<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:      #040d1a;
  --surface: #071628;
  --surface2:#0a1e35;
  --border:  #0e2d50;
  --orange:  #f7931a;
  --orange2: #ffb347;
  --blue:    #1e90ff;
  --blue2:   #4db8ff;
  --text:    #e8f4ff;
  --muted:   #4a7a9b;
  --green:   #34d399;
  --yellow:  #fbbf24;
  --red:     #f87171;
}

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: "Exo 2", sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* Starfield */
body::before {
  content: "";
  position: fixed; inset: 0;
  background:
    radial-gradient(ellipse at 15% 10%, rgba(30,144,255,.10) 0%, transparent 45%),
    radial-gradient(ellipse at 85% 85%, rgba(247,147,26,.07) 0%, transparent 45%),
    radial-gradient(ellipse at 50% 50%, rgba(30,144,255,.04) 0%, transparent 70%);
  pointer-events: none; z-index: 0;
}
body::after {
  content: "";
  position: fixed; inset: 0;
  background-image:
    radial-gradient(1px 1px at  8% 12%, rgba(255,255,255,.7) 0%, transparent 100%),
    radial-gradient(1px 1px at 22% 35%, rgba(255,255,255,.5) 0%, transparent 100%),
    radial-gradient(1px 1px at 38%  7%, rgba(255,255,255,.6) 0%, transparent 100%),
    radial-gradient(1px 1px at 55% 22%, rgba(255,255,255,.4) 0%, transparent 100%),
    radial-gradient(1px 1px at 70% 55%, rgba(255,255,255,.6) 0%, transparent 100%),
    radial-gradient(1px 1px at 82% 14%, rgba(255,255,255,.5) 0%, transparent 100%),
    radial-gradient(1px 1px at 12% 68%, rgba(255,255,255,.5) 0%, transparent 100%),
    radial-gradient(1px 1px at 48% 88%, rgba(255,255,255,.4) 0%, transparent 100%),
    radial-gradient(1px 1px at 63% 72%, rgba(255,255,255,.5) 0%, transparent 100%),
    radial-gradient(1px 1px at 93% 42%, rgba(255,255,255,.4) 0%, transparent 100%),
    radial-gradient(1px 1px at 30% 92%, rgba(255,255,255,.3) 0%, transparent 100%),
    radial-gradient(1px 1px at 77% 30%, rgba(255,255,255,.4) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

.page { position: relative; z-index: 1; max-width: 900px; margin: 0 auto; padding: 0 24px 80px; }

/* ── Header ── */
header {
  text-align: center;
  padding: 60px 0 48px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 48px;
}

.logo-badge {
  display: inline-block;
  font-family: "Rajdhani", sans-serif;
  font-size: 11px; letter-spacing: 4px; text-transform: uppercase;
  color: var(--orange); margin-bottom: 16px;
  animation: fadeUp .6s ease both;
}

h1 {
  font-family: "Rajdhani", sans-serif;
  font-size: clamp(2.4rem, 8vw, 4rem);
  font-weight: 700; letter-spacing: .06em;
  text-transform: uppercase; line-height: 1;
  margin-bottom: 12px;
  animation: fadeUp .7s ease both;
}
h1 .blue   { color: var(--blue2); }
h1 .orange { color: var(--orange); }

.tagline {
  color: var(--muted); font-size: .9rem;
  letter-spacing: .15em; text-transform: uppercase; font-weight: 300;
  margin-bottom: 20px;
  animation: fadeUp .8s ease both;
}

.header-note {
  display: inline-block;
  background: rgba(247,147,26,.1);
  border: 1px solid rgba(247,147,26,.3);
  color: var(--orange2);
  font-size: .75rem; padding: 6px 18px; border-radius: 100px;
  letter-spacing: .15em; font-weight: 600;
  animation: fadeUp .9s ease both;
}

/* ── Divider ── */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), var(--blue), var(--border), transparent);
  margin: 36px 0;
}

/* ── Section title ── */
.section-label {
  font-family: "Rajdhani", sans-serif;
  font-size: .7rem; letter-spacing: .3em; text-transform: uppercase;
  color: var(--muted); margin-bottom: 20px;
  display: flex; align-items: center; gap: 12px;
}
.section-label::after {
  content: ""; flex: 1; height: 1px;
  background: linear-gradient(90deg, var(--border), transparent);
}

/* ── Platform cards 3x3 grid ── */
.platforms {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-bottom: 48px;
}
@media (max-width: 700px) { .platforms { grid-template-columns: 1fr 1fr; } }
@media (max-width: 480px) { .platforms { grid-template-columns: 1fr; } }

.platform-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  display: flex; flex-direction: column;
  padding: 26px 22px 22px;
  transition: border-color .25s, transform .2s, box-shadow .25s;
  text-decoration: none; color: inherit;
  animation: fadeUp .5s ease both;
  position: relative; min-height: 230px;
}
.platform-card:hover {
  border-color: var(--orange);
  transform: translateY(-3px);
  box-shadow: 0 12px 40px rgba(247,147,26,.14);
}
.platform-card::before {
  content: "";
  position: absolute; inset: 0; border-radius: 18px;
  background: radial-gradient(ellipse at top left, rgba(30,144,255,.05) 0%, transparent 65%);
  opacity: 0; transition: opacity .25s; pointer-events: none;
}
.platform-card:hover::before { opacity: 1; }
.platform-card:nth-child(1) { animation-delay: .05s; }
.platform-card:nth-child(2) { animation-delay: .10s; }
.platform-card:nth-child(3) { animation-delay: .15s; }
.platform-card:nth-child(4) { animation-delay: .20s; }
.platform-card:nth-child(5) { animation-delay: .25s; }
.platform-card:nth-child(6) { animation-delay: .30s; }

.platform-rank {
  font-family: "Rajdhani", sans-serif;
  font-size: 2rem; font-weight: 700;
  color: var(--border); line-height: 1;
  margin-bottom: 10px; transition: color .2s;
}
.platform-card:hover .platform-rank { color: var(--orange); }

.platform-body { flex: 1; display: flex; flex-direction: column; gap: 6px; }
.platform-top  { display: flex; align-items: flex-start; gap: 8px; flex-wrap: wrap; margin-bottom: 2px; }

.platform-name {
  font-family: "Rajdhani", sans-serif;
  font-size: 1.05rem; font-weight: 700; letter-spacing: .04em;
  text-transform: uppercase; color: var(--text); line-height: 1.2;
}

.badge-pill {
  font-size: .57rem; padding: 2px 7px; border-radius: 100px;
  font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  font-family: "Exo 2", sans-serif; white-space: nowrap; margin-top: 2px;
}
.badge-green  { background: rgba(52,211,153,.12); border: 1px solid rgba(52,211,153,.3); color: var(--green); }
.badge-yellow { background: rgba(251,191,36,.12);  border: 1px solid rgba(251,191,36,.3);  color: var(--yellow); }
.badge-blue   { background: rgba(77,184,255,.12);  border: 1px solid rgba(77,184,255,.3);  color: var(--blue2); }

.platform-desc { font-size: .78rem; color: var(--muted); line-height: 1.55; flex: 1; }

.platform-stats {
  display: flex; flex-direction: column; gap: 3px;
  margin-top: auto; padding-top: 12px; border-top: 1px solid var(--border);
}
.stat { font-size: .64rem; font-family: "Exo 2", sans-serif; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; }
.stat-gpu   { color: var(--blue2); }
.stat-quota { color: var(--orange2); }
.stat-note  { color: var(--muted); }

.platform-arrow {
  display: inline-block; margin-top: 12px;
  font-size: .72rem; font-family: "Rajdhani", sans-serif;
  font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
  color: var(--border); transition: color .2s;
}
.platform-card:hover .platform-arrow { color: var(--orange); }

/* ── Tip box ── */
.tip-box {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 3px solid var(--orange);
  border-radius: 12px; padding: 20px 24px;
  margin-bottom: 48px;
}
.tip-title {
  font-family: "Rajdhani", sans-serif;
  font-size: .7rem; letter-spacing: .3em; text-transform: uppercase;
  color: var(--orange); margin-bottom: 10px;
}
.tip-text { font-size: .85rem; color: var(--muted); line-height: 1.7; }
.tip-text strong { color: var(--text); }

/* ── Colab link ── */
.colab-banner {
  background: linear-gradient(135deg, rgba(247,147,26,.12), rgba(255,179,71,.06));
  border: 1px solid rgba(247,147,26,.3);
  border-radius: 16px; padding: 28px 32px;
  text-align: center; margin-bottom: 48px;
